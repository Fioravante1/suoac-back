# ============================================================
# SUOAC Backend - Variáveis de Ambiente (Template)
# ============================================================
# Este é o template de referência. Para configurar seu ambiente:
#
#   npm run setup:env
#
# O script gera .env automaticamente com secrets aleatórios.
# Nunca commite .env, .env.staging ou .env.production no Git.
# ============================================================

# ── Database ────────────────────────────────────────────────────
# Dev (Docker local, porta 5432):
DATABASE_URL=postgresql://suoac:suoac_dev@localhost:5432/suoac_dev

# Staging/Prod (Neon): Configurar nos respectivos .env.staging / .env.production
# DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/suoac?sslmode=require
# DIRECT_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/suoac?sslmode=require

# ── App ─────────────────────────────────────────────────────────
PORT=3000

# Valores válidos: development | test | staging | production
# - development: pino-pretty ativado, Swagger habilitado
# - test:        usado pelos testes E2E (banco isolado na porta 5433)
# - staging:     JSON logs, Swagger habilitado (homologação no Railway)
# - production:  JSON logs, Swagger desabilitado (produção no Railway)
NODE_ENV=development

# ── Logging ────────────────────────────────────────────────────
# Níveis: fatal, error, warn, info, debug, trace
LOG_LEVEL=debug

# ── Security ──────────────────────────────────────────────────
# Pepper para hashing de senhas (Argon2). Gerar com:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PASSWORD_PEPPER=gerar-um-valor-aleatorio-de-64-caracteres-hex

# Chave de criptografia AES-256-GCM para dados sensíveis (RG). Gerar com:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=gerar-um-valor-aleatorio-para-encryption-key

# JWT para autenticacao
# Gerar com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=gerar-um-valor-aleatorio-para-jwt-secret
JWT_REFRESH_SECRET=gerar-um-valor-aleatorio-para-jwt-refresh-secret
JWT_EXPIRATION=900
JWT_REFRESH_EXPIRATION=604800

# ── CORS ─────────────────────────────────────────────────────────
# Origens permitidas (comma-separated). Apenas staging/prod.
# Em dev, localhost com qualquer porta é permitido automaticamente.
ALLOWED_ORIGINS=https://suoac.example.com

# ── Rate Limiting ────────────────────────────────────────────────
# Requests por minuto por IP (default: 100)
RATE_LIMIT_MAX=100

# ============================================================
# AMBIENTES REMOTOS (Staging / Produção)
# ============================================================
# Para operar contra staging ou produção, crie os arquivos:
#
#   .env.staging     → NODE_ENV=staging   + DATABASE_URL/DIRECT_URL do Neon
#   .env.production  → NODE_ENV=production + DATABASE_URL/DIRECT_URL do Neon
#
# E use os scripts dedicados:
#
#   npm run db:migrate:staging   # aplica migrations em staging
#   npm run db:seed:staging      # roda seed em staging
#   npm run db:migrate:prod      # aplica migrations em produção
#   npm run db:seed:prod         # roda seed em produção
#
# ⚠️  Staging e produção pedem confirmação interativa antes de executar.
# ============================================================
