        {
          "name": "Create Event",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('eventId', body.id);",
                  "  if (body.days && body.days.length > 0) {",
                  "    pm.collectionVariables.set('eventDayId', body.days[0].id);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Assembleia SP 2026\",\n  \"type\": \"ASSEMBLY\",\n  \"ticketPrice\": 25.00,\n  \"registrationDeadline\": \"2026-06-01\",\n  \"paymentDeadline\": \"2026-06-15\",\n  \"venue\": \"Salão Central\",\n  \"address\": \"Rua das Flores, 100\",\n  \"city\": \"São Paulo\",\n  \"state\": \"SP\",\n  \"date\": \"2026-07-10\",\n  \"departureTime\": \"06:00\",\n  \"returnTime\": \"18:00\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/circuits/:circuitId/events",
